NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/ImproveInfrastructure
JWT_SECRET=replace-with-a-strong-secret

# Optional: Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: Brevo (for email notifications)
BREVO_API_KEY=
BREVO_SENDER=no-reply@your-city.gov
BREVO_SMTP_USER=

# Optional: client API base URL (empty means same origin)
NEXT_PUBLIC_API_BASE_URL=